{
  "name": "roadtrip",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "node ./scripts/kill-port.mjs 3000 && pnpm --filter @roadtrip/web dev",
    "dev:api": "node ./scripts/kill-port.mjs 3001 && pnpm --filter @roadtrip/api dev",
    "dev:mobile": "pnpm --filter @roadtrip/mobile start",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "verify": "pnpm lint && pnpm test:coverage && pnpm build && npx vercel build || echo 'Skipping vercel build (not linked or not authenticated)'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install",
    "audit:warn": "pnpm audit --audit-level=moderate || true",
    "audit:gate": "pnpm audit --audit-level=high"
  },
  "devDependencies": {
    "@eslint/js": "^9.1.0",
    "@types/node": "^22.15.30",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "eslint": "^9.1.0",
    "eslint-config-next": "^15.5.14",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "globals": "^15.3.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "turbo": "^2.0.3",
    "typescript": "5.5.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "tar": "^7.5.11",
      "esbuild": "^0.25.0",
      "fast-xml-parser": "^5.5.7",
      "send": "^0.19.0"
    }
  }
}
