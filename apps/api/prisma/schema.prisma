generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id
  email     String?  @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Trip {
  id         String    @id @default(uuid())
  userId     String
  name       String
  originLat  Float
  originLng  Float
  filters    Json
  shareToken String?   @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  stops      TripStop[]

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model TripStop {
  id        String   @id @default(uuid())
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripId    String
  placeId   String
  name      String
  order     Int
  lat       Float
  lng       Float
  notes     String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@index([placeId])
  @@unique([tripId, order])
}

model SponsoredPlace {
  id          String   @id @default(uuid())
  placeId     String   @unique
  title       String
  description String
  imageUrl    String?
  url         String?
  active      Boolean  @default(true)
  lat         Float?
  lng         Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
  @@index([title])
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String?
  type      String
  payload   Json
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model TripPlanCache {
  id              String   @id @default(uuid())
  location        String
  locationKey     String?
  centerLat       Float
  centerLng       Float
  radiusKm        Float
  themesKey       String
  maxOptions      Int
  options         Json
  validOptions    Int
  engagementScore Int      @default(0)
  lastServedAt    DateTime?
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([expiresAt])
  @@index([themesKey, radiusKm, maxOptions, expiresAt])
  @@index([centerLat, centerLng])
  @@index([engagementScore, updatedAt])
  @@index([locationKey])
}
