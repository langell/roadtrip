{
  "name": "@roadtrip/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/kill-port.mjs 3001 && tsx watch src/server.ts",
    "start": "NODE_ENV=production node dist/server.js",
    "build": "pnpm --filter @roadtrip/types build && PRISMA_GENERATE_SKIP_AUTOINSTALL=1 prisma generate --schema ./prisma/schema.prisma && tsc -p tsconfig.json",
    "postinstall": "PRISMA_GENERATE_SKIP_AUTOINSTALL=1 prisma generate --schema ./prisma/schema.prisma",
    "lint": "eslint src",
    "test": "vitest run",
    "db:push": "prisma db push --skip-generate",
    "db:migrate": "prisma migrate dev --skip-generate"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/client": "5.11.0",
    "@roadtrip/types": "workspace:*",
    "@trpc/server": "11.0.0-rc.419",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jose": "^6.2.2",
    "pino": "^8.19.0",
    "superjson": "^2.2.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.30",
    "@types/supertest": "^2.0.16",
    "@vitest/coverage-v8": "^1.6.1",
    "prisma": "5.11.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "5.5.4",
    "vitest": "^1.6.1"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma"
  }
}
