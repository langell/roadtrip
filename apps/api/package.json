{
  "name": "@roadtrip/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "NODE_ENV=production node dist/server.js",
    "build": "tsc -p tsconfig.json",
