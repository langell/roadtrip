  },
  "dependencies": {
    "@prisma/client": "5.11.0",
    "@roadtrip/types": "workspace:*",
    "@trpc/server": "11.0.0-rc.419",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "pino": "^8.19.0",
    "superjson": "^2.2.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/supertest": "^2.0.16",
    "@vitest/coverage-v8": "^4.1.1",
    "prisma": "5.11.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2",
    "vitest": "^4.1.1"
  },
  "prisma": {
    "schema": "../../prisma/schema.prisma"
