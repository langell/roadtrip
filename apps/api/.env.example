DATABASE_URL=
LOG_LEVEL=info
PORT=3001

# Requires Geocoding API + Places API (New) with places:searchText allowed.
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_BASE_URL=https://maps.googleapis.com
GOOGLE_PLACES_RESULT_LIMIT=6
GOOGLE_PLACES_CACHE_TTL_SECONDS=300
GOOGLE_PLACES_TIMEOUT_MS=8000
GOOGLE_PLACES_RETRY_COUNT=2

# Must match AUTH_SECRET on the web app — used to verify session JWTs.
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Public URL of the web app — used to build share links (e.g. https://hiptrip.net)
PUBLIC_SITE_URL=

# CORS — comma-separated allowed origins (e.g. https://hiptrip.net)
CORS_ORIGIN=

ANON_SUGGESTIONS_RATE_LIMIT_WINDOW_MS=300000
ANON_SUGGESTIONS_RATE_LIMIT_MAX=60
ANON_PHOTO_RATE_LIMIT_WINDOW_MS=300000
ANON_PHOTO_RATE_LIMIT_MAX=200

OTEL_ENABLED=false
OTEL_SERVICE_NAME=roadtrip-api
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
