generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trips     Trip[]
}

model Trip {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  name      String
  originLat Float
  originLng Float
  filters   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stops     TripStop[]
}

model TripStop {
  id        String @id @default(uuid())
  trip      Trip   @relation(fields: [tripId], references: [id])
  tripId    String
  placeId   String
  name      String
  order     Int
  lat       Float
  lng       Float
  notes     String?
}

model SponsoredPlace {
  id          String   @id @default(uuid())
  placeId     String   @unique
  title       String
  description String
  url         String?
  active      Boolean  @default(true)
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String?
  type      String
  payload   Json
  createdAt DateTime @default(now())
}
